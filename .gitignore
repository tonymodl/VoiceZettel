# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Obsidian Vault (personal data — NEVER commit)
/VoiceZettel/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# user data (NEVER commit — contains PII, emails, conversations)
data/memory_*.json
data/chat_*.json
data/tokens_*.json
data/settings/*.json
data/logs/*.json
data/*.db

# PWA service worker (generated by next-pwa)
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/swe-worker-*.js
public/fallback-*.js

# Python
__pycache__/
*.py[cod]
*.egg-info/
venv/
.venv/

# Telegram session (auth tokens — NEVER commit)
services/telegram/session/
*.session
*.session-journal

# ChromaDB data (large, regeneratable)
services/indexer/chroma_data/

# SQLite WAL/SHM (transient)
data/*.db-shm
data/*.db-wal

# Large binaries (should not be in git)
python-installer.exe
get-pip.py

# Antigravity agent logs
.antigravity/

# Allowed users (contains PII)
data/allowed_users.json

# Export tracker (regeneratable)
services/telegram/export_progress.json
